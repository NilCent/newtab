# 依赖目录
node_modules/

# 构建输出目录
dist/
build/
out/

# 环境变量文件（可能包含密钥）
.env
.env.local
.env.*.local

# 日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 编辑器/IDE 配置（可选，按需保留）
.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统生成的文件
.DS_Store
Thumbs.db
desktop.ini

# 缓存目录
.cache/
.parcel-cache/

# 测试覆盖率报告
coverage/

# 项目特有临时文件
*.tmp
*.temp